# 飞书扫码登录配置
# 在飞书开放平台创建「网页应用」后填写以下字段
# 文档：https://open.feishu.cn/document/qr-code-scanning-login-for-web-app/introduction

FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 回调地址，需与飞书应用后台「重定向 URL」完全一致
# 本地开发默认值：http://127.0.0.1:5002/auth/callback
# FEISHU_REDIRECT_URI=https://your-domain.com/auth/callback

# Web 服务器配置（可选）
# MD2PPT_HOST=0.0.0.0
# MD2PPT_PORT=5002
# MD2PPT_DEBUG=false
